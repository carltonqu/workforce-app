// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  MANAGER
  HR
  EMPLOYEE
}

enum Tier {
  FREE
  PRO
  ADVANCED
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  tier         Tier     @default(FREE)
  dbUrl        String?  // Tenant Turso DB URL (null = uses master DB)
  dbAuthToken  String?  // Tenant Turso DB auth token
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users     User[]
  schedules Schedule[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  tier      Tier     @default(FREE)
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org           Organization?  @relation(fields: [orgId], references: [id])
  timeEntries   TimeEntry[]
  payrollEntries PayrollEntry[]
  notifications  Notification[]
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  clockIn         DateTime
  clockOut        DateTime?
  overtimeMinutes Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Schedule {
  id        String   @id @default(cuid())
  orgId     String
  weekStart DateTime
  shifts    String   // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model PayrollEntry {
  id            String   @id @default(cuid())
  userId        String
  periodStart   DateTime
  periodEnd     DateTime
  periodType    String   @default("MONTHLY")
  status        String   @default("DRAFT")
  rateType      String   @default("MONTHLY")
  rate          Float    @default(0)
  dailyRate     Float    @default(0)
  hourlyRate    Float    @default(0)
  daysWorked    Float    @default(0)
  hoursWorked   Float    @default(0)
  lateMinutes   Float    @default(0)
  undertimeMinutes Float @default(0)
  absenceDays   Float    @default(0)
  basicPay      Float    @default(0)
  lateDeduction Float    @default(0)
  undertimeDeduction Float @default(0)
  absenceDeduction Float @default(0)
  otPay         Float    @default(0)
  nightDiffPay  Float    @default(0)
  holidayPay    Float    @default(0)
  allowancesJson String  @default("[]")
  totalAllowances Float  @default(0)
  grossPay      Float    @default(0)
  sssEmployee   Float    @default(0)
  sssEmployer   Float    @default(0)
  philhealthEmployee Float @default(0)
  philhealthEmployer Float @default(0)
  pagibigEmployee Float  @default(0)
  pagibigEmployer Float  @default(0)
  withholdingTax Float   @default(0)
  taxableIncome Float    @default(0)
  otherDeductionsJson String @default("[]")
  totalOtherDeductions Float @default(0)
  netPay        Float    @default(0)
  regularHours  Float    @default(0)
  overtimeHours Float    @default(0)
  payRate       Float    @default(0)
  deductions    Float    @default(0)
  total         Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  type      String
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Employee {
  id               String   @id @default(cuid())
  employeeId       String   @unique
  fullName         String
  profilePhoto     String?
  email            String
  phoneNumber      String?
  address          String?
  emergencyContact String?  // JSON: { name, relationship, phone }
  dateOfBirth      DateTime?
  gender           String?
  hireDate         DateTime?
  employmentStatus String   @default("Active") // Active, Inactive, On Leave, Terminated
  department       String?
  position         String?
  branchLocation   String?
  reportingManager String?
  employmentType   String?  // Full-time, Part-time, Contract, Probationary
  payrollType      String?  // Monthly, Semi-monthly, Weekly, Daily
  salaryRate       Float?
  governmentTaxIds String?  // JSON: { sss, philhealth, pagibig, tin }
  bankDetails      String?  // JSON: { bankName, accountName, accountNumber }
  uploadedDocuments String? // JSON array: [{ name, url, uploadedAt }]
  orgId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Asset {
  id           String   @id @default(cuid())
  assetCode    String   @unique
  name         String
  type         String
  serialNumber String?
  brand        String?
  model        String?
  condition    String   @default("Good")
  status       String   @default("Available")
  notes        String?
  orgId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments  AssetAssignment[]
  requests     AssetRequest[]
}

model AssetAssignment {
  id                String    @id @default(cuid())
  assetId           String
  employeeId        String
  employeeDbId      String
  assignedBy        String
  conditionOnAssign String    @default("Good")
  dateAssigned      DateTime  @default(now())
  dateReturned      DateTime?
  isActive          Boolean   @default(true)
  notes             String?
  createdAt         DateTime  @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetRequest {
  id           String   @id @default(cuid())
  employeeId   String
  assetId      String?
  assetType    String
  reason       String
  urgency      String   @default("Normal")
  status       String   @default("Pending")
  adminComment String?
  requestedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  asset Asset? @relation(fields: [assetId], references: [id])
}
